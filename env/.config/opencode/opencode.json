{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "skill": {
      "*": "allow"
    },
    "todoread": "allow",
    "todowrite": "allow"
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  // "plugins": [
    // "oh-my-openagent@latest"
    // "oh-my-opencode@2.5.4"
  // ],
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "*.lock",
      "**/*.log",
      ".cache/**",
      "build/**",
      "__pycache__/**",
      ".venv/**",
      "venv/**"
    ]
  },
  "mcp": {
    "google-drive": {
      "type": "local",
      "enable": true,
      "command": ["npx", "-y", "@piotr-agier/google-drive-mcp"],
      "env": {
        // "GOOGLE_DRIVE_OAUTH_CREDENTIALS": "/home/sd/.config/google-drive-mcp/gcp-oauth.keys.json"
        "GOOGLE_DRIVE_CREDENTIALS_JSON": "/home/sd/.config/google-drive-mcp/gcp-oauth.keys.json"
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-0ebfd4bc-7513-40c5-82be-5b39e91582eb"
      },
      "enabled": true
    }
  }
}
